{
  "name": "@westline/style-preview",
  "version": "0.1.3",
  "private": false,
  "description": "Reusable style preview engine for Westline client projects.",
  "license": "UNLICENSED",
  "author": "Westline Marketing",
  "homepage": "https://github.com/westline-marketing/westline-style-preview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/westline-marketing/westline-style-preview.git"
  },
  "bugs": {
    "url": "https://github.com/westline-marketing/westline-style-preview/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "GUIDE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "release:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
